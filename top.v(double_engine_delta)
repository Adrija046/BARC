module top(
    input clk,
    input rst_n,
    input decay_pulse,
    input ack_clear,

    output reg [31:0] delta1_snap,
    output reg [31:0] delta2_snap,
    output reg [31:0] rand_num,
    output reg data_valid
);

 reg e1_start;
 reg e1_stop;
 reg e2_start;
 reg e2_stop;
 reg[31:0] pulse_count;
 wire done1;
 wire done2;
 reg e1_ready;
 reg e2_ready;
 reg [2:0]sync;



 wire count_enable1;
 wire counter_reset1;
 wire delta_enable1;


 wire pulse_rise;
 wire count_enable2;
 wire  counter_reset2;
 wire  delta_enable2;

// Synchronizer


reg sync2_d;

always @(posedge clk)
begin
    if(!rst_n)
        sync <= 3'd0;
    else
    begin
        sync[0] <= decay_pulse;
        sync[1] <= sync[0];
        sync[2] <= sync[1];
    end
end

always @(posedge clk)
begin
    if(!rst_n)
        sync2_d <= 1'b0;
    else
        sync2_d <= sync[2];
end



assign pulse_rise = sync[2] & ~sync2_d;



//pulsecount_logic
always @(posedge clk)
begin
    if(!rst_n)
        pulse_count <= 32'd0;
    else if(pulse_rise)
        pulse_count <= pulse_count + 1'b1;
end


always @(posedge clk)
begin
    if(!rst_n)
    begin
        e1_start <= 0;
        e1_stop  <= 0;
        e2_start <= 0;
        e2_stop  <= 0;
    end
    else
    begin
        e1_start <= 0;
        e1_stop  <= 0;
        e2_start <= 0;
        e2_stop  <= 0;

        if(pulse_rise)
        begin
            case(pulse_count[1:0])

                2'd0: begin e1_start <= 1'b1; 
                            e2_stop  <= 1'b1;
                      end
                2'd1: begin e1_stop  <= 1'b1;
                            e2_start <= 1'b1;
                      end    
                2'd2:begin  
                    e2_stop <= 1'b1;
                    e1_start<=1'b1;
                    
                     end
                    
                2'd3:begin
                     e1_stop  <= 1'b1;
                     e2_start <= 1'b1;
                     end
                     
               default:begin
                       e1_stop<=1;
                       e2_stop<=1;
               
                       end
            endcase
        end
    end
end

// Engine outputs
//
wire [31:0] counter1;
wire [31:0] counter2;



//
// Engine 1
//
rng engine1 (
    .clk(clk),
    .rst_n(rst_n),

    .start(e1_start),
    .stop(e1_stop),

    .counter(counter1),
    .delta(delta1),
    .done(done1),
    .counter_reset(counter_reset1),
    .count_enable(count_enable1),
    .delta_enable(delta_enable1)
);

//
// Engine 2
//
rng engine2 (
    .clk(clk),
    .rst_n(rst_n),

    .start(e2_start),
    .stop(e2_stop),

    .counter(counter2),
    .delta(delta2),
    .done(done2),
    .counter_reset(counter_reset2),
    .count_enable(count_enable2),
    .delta_enable(delta_enable2)
);

wire [31:0] delta1;
wire [31:0] delta2;

always @(posedge clk)
begin
    if(!rst_n)
    begin
        e1_ready    <= 1'b0;
        e2_ready    <= 1'b0;

        delta1_snap <= 32'd0;
        delta2_snap <= 32'd0;
        rand_num    <= 32'd0;

        data_valid  <= 1'b0;
    end
    else
    begin

        //--------------------------------
        // Latch engine completion
        //--------------------------------
        if(!data_valid)
        begin
        if(done1)
            e1_ready <= 1'b1;

        if(done2)
            e2_ready <= 1'b1;
         end
        //--------------------------------
        // New synchronized sample ready
        //--------------------------------
       
        if(((e1_ready || done1) && (e2_ready || done2)) && !data_valid)
        begin
            delta1_snap <= delta1;
            delta2_snap <= delta2;

            if(delta1 > delta2)
                rand_num <= delta1 - delta2;
            else
                rand_num <= delta2 - delta1;

            data_valid <= 1'b1;

            e1_ready <= 1'b0;
            e2_ready <= 1'b0;
        end
         else if(ack_clear)
        begin
          data_valid <= 1'b0;
           e1_ready   <= 1'b0;
           e2_ready   <= 1'b0;
        end
        
    end
end
endmodule
